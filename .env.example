# File: .env.example
# Source-of-truth schema: apps/web/src/env.js
# Copy this file to .env for local development.

# Local runtime
PORT=3222
HOSTNAME=0.0.0.0
NODE_ENV=development

# NextAuth / OAuth (required)
# Generate a secret: openssl rand -base64 32
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET="replace-with-a-32+-character-secret"
NEXTAUTH_URL="http://127.0.0.1:3222"
AUTH_TRUST_HOST=true
AUTH_DISCORD_ID="your-discord-app-id"
AUTH_DISCORD_SECRET="your-discord-app-secret"
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Spotify OAuth (optional)
AUTH_SPOTIFY_ENABLED=false
NEXT_PUBLIC_AUTH_SPOTIFY_ENABLED=false
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
# Database (required at runtime)
# DATABASE_URL remains the canonical frontend key, but Prisma Postgres style
# aliases are also accepted by the frontend runtime and migration helpers.
DATABASE_URL="postgres://token:secret@db.prisma.io:5432/postgres?sslmode=require"
# Optional aliases for managed Postgres providers:
# POSTGRES_PRISMA_URL="${DATABASE_URL}"
# PRISMA_DATABASE_URL="${DATABASE_URL}"
# POSTGRES_URL="${DATABASE_URL}"
# POSTGRES_URL_NON_POOLING="${DATABASE_URL}"
# DATABASE_URL_UNPOOLED="${DATABASE_URL}"

# Admin database config route (optional)
# Override repository root used by /api/admin/database-config when needed.
# REPO_ROOT="/absolute/path/to/darkfloor-player"
# Optional UI hint overrides shown after saving DATABASE_URL updates.
# ADMIN_DB_CONFIG_FRONTEND_RELOAD_HINT="Restart or reload your frontend process after saving."
# ADMIN_DB_CONFIG_API_RELOAD_HINT="Restart or reload your API process after saving."

# Upstream API (canonical local keys)
API_V2_URL="https://your-api-domain.com"
# Optional multi-origin failover list for API V2. Comma or newline separated.
# The frontend server will prefer healthy origins and fail over GET/HEAD requests
# when a node times out or returns 502/503/504.
# API_V2_URLS="https://api-a.example.com,https://api-b.example.com,https://api-c.example.com"
# Optional pool-specific lists. When unset, each pool falls back to API_V2_URLS,
# then finally API_V2_URL.
# API_V2_READ_URLS="https://api-a.example.com,https://api-b.example.com"
# API_V2_WRITE_URLS="https://api-a.example.com"
# API_V2_STREAM_URLS="https://api-a.example.com,https://api-c.example.com"
# Optional when browser-side auth helpers must talk to a separate auth/API host.
# NEXT_PUBLIC_AUTH_API_BASE="https://your-auth-api-domain.com"
# Optional health path override. Defaults to /api/health.
# Example: "/health" when the upstream exposes a top-level health endpoint.
# SONGBIRD_API_HEALTH_URI="/health"

# Upstream auth key
UNIVERSAL_KEY="your-api-key"
# Optional override only when the upstream x-api-key should differ from UNIVERSAL_KEY.
# BLUESIX_API_KEY="your-api-key"

# OAuth/auth debugging (optional)
# Set true to trace auth flow end-to-end in logs.
AUTH_DEBUG_OAUTH=false
NEXT_PUBLIC_AUTH_DEBUG_OAUTH=false
# Frontend callback/auth diagnostics panel (0|1).
NEXT_PUBLIC_AUTH_DEBUG=0
# Used by /api/auth/spotify/debug route.
AUTH_DEBUG_TOKEN="your-auth-debug-token"

# Optional client/runtime metadata
NEXT_PUBLIC_APP_VERSION="0.0.0"
ELECTRON_BUILD=false
# NEXT_PUBLIC_LOG_LEVEL=DEBUG # DEBUG | INFO | WARN | ERROR
# SKIP_ENV_VALIDATION=false   # Only for controlled test/debug use.

# Legacy aliases remain supported in code for compatibility, but new env files
# should stick to the canonical keys above.

# Admin database config route
# Set only when the runtime working directory is not the repo root.
# REPO_ROOT="/absolute/path/to/darkfloor-player"
ADMIN_DB_CONFIG_FRONTEND_RELOAD_HINT="Restart or reload the frontend service after saving."
ADMIN_DB_CONFIG_API_RELOAD_HINT="Restart or reload the API service after saving."
