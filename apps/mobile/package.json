{
  "name": "@starchild/mobile",
  "private": true,
  "version": "1.14.0",
  "type": "module",
  "description": "Starchild React Native Web app workspace",
  "main": "./index.ts",
  "scripts": {
    "dev": "expo start --web",
    "dev:native": "expo start",
    "dev:ios": "expo start --ios",
    "dev:android": "expo start --android",
    "build": "expo export --platform web --output-dir dist",
    "check": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@starchild/config": "workspace:*",
    "@starchild/player-core": "workspace:*",
    "@starchild/types": "workspace:*",
    "@expo/metro-runtime": "^6.1.0",
    "expo": "^55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.0",
    "react-native-web": "0.21.0"
  }
}
